# Obter gratuitamente em: https://console.groq.com
GROQ_API_KEY=gsk_...

# Modelo LLM (fallback: gemma2-9b-it)
GROQ_MODEL=llama-3.3-70b-versatile

# Modelo de embeddings (roda local, sem custo)
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Diretório de persistência do ChromaDB
CHROMA_PERSIST_DIR=./data/processed/embeddings

# Número de chunks recuperados por busca
RETRIEVER_TOP_K=5
